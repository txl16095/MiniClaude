# ============================================================
# MiniClaude 环境配置（开发模式）
# ============================================================
# 复制为 .env 使用：cp .env.example .env
# 正式使用推荐 ~/.claude/settings.json，见 README 和 settings.example.json
#
# 优先级：settings.json > .env
# 以 settings.json 为准，.env 仅在开发调试时作临时覆盖

# ============================================================
# 必填
# ============================================================
ANTHROPIC_API_KEY=your-api-key-here

# ============================================================
# 模型与 API（可选）
# ============================================================
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
# ANTHROPIC_MODEL=deepseek-v4-pro[1m]
# ANTHROPIC_SMALL_FAST_MODEL=deepseek-v4-flash

# ============================================================
# 行为开关（可选）
# ============================================================
DISABLE_TELEMETRY=1
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
# FAST_MODE=1                 # 快速模式
# ENABLE_PROMPT_CACHING_1H=true   # 启用 1 小时 prompt 缓存
